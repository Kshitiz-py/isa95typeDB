                <mxCell id="title" value="PERSONNEL INFORMATION (DIN 62264-2 Section 5.1)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fillColor=none;strokeColor=none;" parent="1" vertex="1">
