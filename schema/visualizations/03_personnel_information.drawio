                <mxCell id="definition_box" value="PERSONNEL MODEL OVERVIEW" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5ff;strokeColor=#01579b;strokeWidth=2;fontSize=12;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="50" y="100" width="1100" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="definition_text" value="Personnel information represents individuals and their classifications, properties, and qualifications. Personnel classes define categories of workers (e.g., &#39;Widget Assembly Operator&#39;), while persons are specific individuals. Properties track qualifications, skills, and availability. Composition relationships require cascading delete enforcement at the application layer." style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fillColor=none;strokeColor=none;" parent="1" vertex="1">
                    <mxGeometry x="70" y="115" width="1060" height="80" as="geometry"/>
