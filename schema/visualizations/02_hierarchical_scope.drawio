  <diagram id="hierarchical_scope" name="Hierarchical Scope">
    <mxGraphModel dx="1000" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1600" background="#ffffff" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        
        <!-- Title -->
        <mxCell id="title" value="HIERARCHICAL SCOPE (DIN 62264-2 Section 4.7 / IEC 62264-1)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="50" y="20" width="1100" height="50" as="geometry"/>
        </mxCell>
        
        <!-- Main Definition Box -->
        <mxCell id="definition_box" value="WHAT IS HIERARCHY SCOPE? (It's an ATTRIBUTE)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5ff;strokeColor=#01579b;strokeWidth=2;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="100" width="1100" height="100" as="geometry"/>
        </mxCell>
        
        <mxCell id="definition_text" value="An attribute used in many other objects to identify WHERE in the equipment hierarchy the exchanged information fits. It defines the SCOPE of the exchanged information (e.g., which Site, Area, or Work Center applies). It identifies the associated instance in the role-based equipment hierarchy. OPTIONAL - not needed if context is determined by exchange mechanism." style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="70" y="115" width="1060" height="80" as="geometry"/>
        </mxCell>
        
        <!-- Left Column: Used By Objects -->
        <mxCell id="used_by_header" value="HIERARCHY SCOPE IS USED BY:" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f57f17;strokeWidth=2;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="220" width="320" height="40" as="geometry"/>
        </mxCell>
        
