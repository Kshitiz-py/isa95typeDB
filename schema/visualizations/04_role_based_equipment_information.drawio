                <mxCell id="definition_box" value="EQUIPMENT MODEL OVERVIEW" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5ff;strokeColor=#01579b;strokeWidth=2;fontSize=12;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="50" y="100" width="1100" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="definition_text" value="Role-based equipment information represents specific equipment, classes of equipment, and their capability tests. Equipment classes define groupings of equipment (e.g., &#39;reactor unit&#39;), while equipment are specific elements (e.g., &#39;Jig 347&#39;). Both can have properties and nested sub-properties. Equipment can be made up of sub-equipment. Composition relationships require cascading delete enforcement at the application layer." style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fillColor=none;strokeColor=none;" parent="1" vertex="1">
                    <mxGeometry x="70" y="115" width="1060" height="80" as="geometry"/>
                </mxCell>
